# -----------------------------------------------------------------------------
# Haze Tool Platform environment template
# Copy this file to .env and replace secrets / host-specific paths before deploy.
# -----------------------------------------------------------------------------

# Compose / image settings
HAZE_VERSION=latest
PUID=1000
PGID=1000
BACKEND_PORT=8000
GATEWAY_PORT=8001
FRONTEND_PORT=8080
HAZE_STORAGE_PATH=./data/storage
HAZE_REGISTRY_PATH=./data/registry

# Host paths mounted into the worker container
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_CONFIG_PATH=/root/.docker
K8S_CONFIG_HOST_PATH=/home/paiwo/.kube/config
K8S_CONFIG_PATH=/run/haze/kubeconfig

# Frontend build
VITE_API_BASE_URL=

# Application
APP_NAME="Haze Tool API"
APP_VERSION="0.1.0"
ENVIRONMENT="production"
DEBUG=false
WEB_CONCURRENCY=2

# Database
DATABASE_URL="mysql+pymysql://haze:change-me@host.docker.internal:3306/haze?charset=utf8mb4"

# Auth / bootstrap admin
JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
INITIAL_ADMIN_NAME="admin"
INITIAL_ADMIN_PHONE="13800138000"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
INITIAL_ADMIN_DEPARTMENT="System Administration"

# URLs / storage
CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:8080"]'
LOCAL_STORAGE_DIR=/app/storage

# Public MCP Gateway base URL. Production example: https://haze.example.com
GATEWAY_PUBLIC_BASE_URL="http://127.0.0.1:8001"

# Production example: DOWNLOAD_PUBLIC_BASE_URL="https://haze.example.com"
DOWNLOAD_PUBLIC_BASE_URL="http://127.0.0.1:8000"
DOWNLOAD_LINK_EXPIRE_MINUTES=30

# Backend MCP test runner
MCP_DOCKER_PREPULL=false
MCP_DOCKER_IMAGES='["node:20-slim","python:3.12-slim"]'

# Gateway
GATEWAY_HOST=0.0.0.0
PROXY_TIMEOUT_SECONDS=30
TRUSTED_MCP_CREDENTIAL_PASSTHROUGH=marketplace-query

# Worker polling
POLL_INTERVAL_SECONDS=5
TASK_LOCK_TIMEOUT_SECONDS=300

# Kubernetes runtime
K8S_IN_CLUSTER=false
K8S_VERIFY_SSL=true
K8S_PROXY_BASE_URL=http://host.docker.internal:8090
K8S_NAMESPACE=haze-runtime
MCP_PLACEHOLDER_IMAGE=node:20-slim
POD_READY_TIMEOUT_SECONDS=120
POD_READY_POLL_SECONDS=5
MCP_CPU_REQUEST=100m
MCP_CPU_LIMIT=500m
MCP_MEMORY_REQUEST=128Mi
MCP_MEMORY_LIMIT=512Mi

# Image registry / build
REGISTRY_URL=localhost:5000
REGISTRY_PROJECT=haze-mcp
REGISTRY_PUSH_ENABLED=true
DOCKER_BUILD_TIMEOUT_SECONDS=300

# Compose registry settings
COMPOSE_PROJECT_NAME=haze
REGISTRY_PORT=5000
REGISTRY_HTTP_ADDR=0.0.0.0:5000
REGISTRY_STORAGE_DELETE_ENABLED=true
REGISTRY_HTTP_RELATIVEURLS=true
